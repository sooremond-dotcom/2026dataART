rules_version = '2';
// =============================================================================
// Firestore 보안 규칙 — 수업용 (프로젝트: data-art-2026)
// -----------------------------------------------------------------------------
// 적용: Firebase 콘솔 → Firestore Database → "규칙" 탭에 붙여넣고 "게시".
//
// 이 앱은 Firebase Auth 를 쓰지 않습니다(이름+PIN 로컬 로그인). 따라서 규칙으로
// 사용자를 인증할 수 없어, 알려진 3개 컬렉션에 한해 읽기/쓰기를 열되 나머지는 전부
// 막고, 문서에 기본 필드·크기 가드를 둡니다. 이는 "수업 기간 한정" 설정입니다.
//
// 권장 운영:
//   • 수업 단원이 끝나면 데이터 내보내기(교사 대시보드) 후 프로젝트를 정리/삭제.
//   • 더 엄격히 하려면 Firebase 익명 인증을 켜고 아래 allow 조건에
//     `&& request.auth != null` 을 추가하세요.
//   • 미성년자 정보이므로 학교 개인정보 방침을 우선합니다.
// =============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function notTooBig() { return request.resource.data.size() < 60; }

    match /works/{id} {
      allow read: if true;
      allow create, update: if notTooBig()
        && request.resource.data.keys().hasAll(['userId', 'kind']);
      allow delete: if true;
    }
    match /feedback/{id} {
      allow read: if true;
      allow create: if notTooBig() && request.resource.data.keys().hasAll(['workId']);
      allow update, delete: if false;   // 피드백은 수정·삭제 불가(기록 보존)
    }
    match /notes/{id} {
      allow read: if true;
      allow create, update: if notTooBig()
        && request.resource.data.keys().hasAll(['userId', 'kind']);
      allow delete: if true;
    }
    match /quizzes/{id} {
      allow read: if true;
      allow create, update: if notTooBig() && request.resource.data.keys().hasAll(['title', 'userId']);
      allow delete: if true;
    }
    match /quizAnswers/{id} {
      allow read: if true;
      allow create: if notTooBig() && request.resource.data.keys().hasAll(['quizId']);
      allow update, delete: if false;   // 답안은 수정·삭제 불가(기록 보존)
    }

    // 그 외 모든 경로는 차단
    match /{document=**} { allow read, write: if false; }
  }
}
